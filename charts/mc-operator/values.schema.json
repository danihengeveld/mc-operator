{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mc-operator Helm chart values",
  "description": "Configuration values for the mc-operator Helm chart",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "object",
      "description": "Operator container image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository",
          "default": "ghcr.io/danihengeveld/mc-operator"
        },
        "tag": {
          "type": "string",
          "description": "Image tag. Defaults to the chart appVersion when empty",
          "default": ""
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "List of image pull secret references",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the secret containing registry credentials"
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "description": "Number of operator replicas",
      "minimum": 1,
      "default": 1
    },
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the fully qualified app name",
      "default": ""
    },
    "resources": {
      "type": "object",
      "description": "Resource requests and limits for the operator pod",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "description": "Minimum resources required",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU request (e.g. 100m)",
              "default": "100m"
            },
            "memory": {
              "type": "string",
              "description": "Memory request (e.g. 64Mi)",
              "default": "64Mi"
            }
          }
        },
        "limits": {
          "type": "object",
          "description": "Maximum resources the operator may consume",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU limit (e.g. 200m)",
              "default": "200m"
            },
            "memory": {
              "type": "string",
              "description": "Memory limit (e.g. 128Mi)",
              "default": "128Mi"
            }
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector labels for the operator pod",
      "default": {}
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for the operator pod",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for the operator pod",
      "default": {}
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration for the operator",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a dedicated ServiceAccount for the operator",
          "default": true
        },
        "annotations": {
          "type": "object",
          "description": "Annotations to add to the ServiceAccount (e.g. for IRSA or Workload Identity)",
          "default": {}
        },
        "name": {
          "type": "string",
          "description": "ServiceAccount name. Auto-generated from the release name when create is true and name is empty",
          "default": ""
        }
      }
    },
    "namespace": {
      "type": "object",
      "description": "Namespace where the operator is deployed",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create the operator namespace",
          "default": true
        },
        "name": {
          "type": "string",
          "description": "Name of the operator namespace",
          "default": "mc-operator-system"
        }
      }
    },
    "webhooks": {
      "type": "object",
      "description": "Admission webhook configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable validating and mutating admission webhooks",
          "default": true
        },
        "port": {
          "type": "integer",
          "description": "HTTPS port for the webhook server",
          "minimum": 1,
          "maximum": 65535,
          "default": 5001
        },
        "certManager": {
          "type": "object",
          "description": "cert-manager integration for webhook TLS",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Use cert-manager to provision TLS certificates for the webhook server",
              "default": false
            },
            "issuerRef": {
              "type": "object",
              "description": "Reference to a cert-manager Issuer or ClusterIssuer",
              "default": {}
            }
          }
        }
      }
    },
    "leaderElection": {
      "type": "object",
      "description": "Leader election configuration for high-availability deployments",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable leader election so only one replica actively reconciles at a time",
          "default": true
        }
      }
    },
    "logLevel": {
      "type": "string",
      "description": "Log verbosity level for the operator",
      "enum": ["Trace", "Debug", "Information", "Warning", "Error", "Critical"],
      "default": "Information"
    },
    "metrics": {
      "type": "object",
      "description": "Metrics endpoint configuration (future use)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable the metrics endpoint",
          "default": false
        },
        "port": {
          "type": "integer",
          "description": "Port for the metrics endpoint",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        }
      }
    }
  }
}
